      "dependencies": [],
      "enabled": true,
      "class_name": "DifficultyManager",
      "config": {
        "default_difficulty": "normal",
        "allow_change_midgame": true
      }
    },
    {
      "name": "goals_challenges_system",
      "version": "1.0.0",
