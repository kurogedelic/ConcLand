      "dependencies": [],
      "enabled": true,
      "class_name": "AdvancedTrafficSystem",
      "config": {
        "max_pathfinding_distance": 50,
        "bus_spawn_interval": 300,
        "traffic_light_cycle": 180
      }
    },
    {
