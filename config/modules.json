    {
      "name": "train_system",
      "version": "1.0.0",
      "description": "鉄道システム / Railway System",
      "dependencies": [],
      "enabled": true,
      "class_name": "TrainSystem",
      "config": {
        "max_trains": 10,
        "train_speed": 2,
        "auto_spawn": true
      }
    },
    {
      "name": "title_menu_system",
      "version": "1.0.0",
      "description": "タイトル・メニューシステム / Title Menu System",
      "dependencies": [],
      "enabled": true,
      "class_name": "GameLauncher",
      "config": {
        "skip_title": false,
        "auto_load_last": false,
        "menu_animation": true
