        "initial_funds": 10000,
        "tax_rates": {
          "residential": 0.05,
          "commercial": 0.08,
          "industrial": 0.10
        }
      }
    },
    {
      "name": "disaster_system",
      "version": "1.0.0",
      "description": "災害シミュレーションシステム / Disaster Simulation System",
      "dependencies": [],
      "enabled": true,
      "class_name": "DisasterSystem",
      "config": {
        "disaster_probability": 0.001,
        "warning_time": 300,
        "damage_multiplier": 1.0
      }
    },
    {
      "name": "sound_effects_system",
      "version": "1.0.0",
      "description": "サウンドエフェクトシステム / Sound Effects System",
      "dependencies": [],
      "enabled": false,
      "class_name": "SoundEffectsSystem",
      "config": {
        "master_volume": 0.7,
        "sfx_volume": 0.8,
        "ambient_volume": 0.5
      }
    },
    {
      "name": "visual_system",
      "version": "1.0.0",
